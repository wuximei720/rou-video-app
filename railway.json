{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm ci --ignore-scripts && DATABASE_URL=postgresql://localhost:5432/app npx prisma generate && npm run build",
    "nixpacksConfig": {
      "pkgs": ["ffmpeg"],
      "phases": {
        "install": {
          "skip": true
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "env": {
    "DOUBAO_MODEL_ID": "doubao-seed-2-0-lite-260428",
    "SEEDANCE_MODEL_ID": "doubao-seedance-2-0"
  }
}
